<?xml version="1.0" encoding="utf-8"?>
<!--
  Splash screen background: white fill + centered brand logo.
  Used as android:windowBackground in SplashTheme.
  To replace logo: swap @drawable/ic_splash_logo with your brand asset.
  android:width/android:height on layer-list item requires API 23+ (minSdk 24, safe).
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/splash_background"/>
    <item
        android:gravity="center"
        android:width="96dp"
        android:height="96dp"
        android:drawable="@drawable/ic_splash_logo"/>
</layer-list>
