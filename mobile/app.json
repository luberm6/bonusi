{
  "expo": {
    "name": "AutoService",
    "slug": "autoservice",
    "entryPoint": "./index.js",
    "icon": "./assets/icon.png",
    "plugins": [
      "expo-image-picker",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Orbitron-Bold.ttf",
            "./assets/fonts/Orbitron-Black.ttf",
            "./assets/fonts/Rajdhani-SemiBold.ttf",
            "./assets/fonts/Rajdhani-Bold.ttf",
            "./assets/fonts/Montserrat-Regular.ttf",
            "./assets/fonts/Montserrat-Bold.ttf"
          ]
        }
      ]
    ],
    "ios": {
      "bundleIdentifier": "com.anonymous.autoservice",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Для отправки фото в чат",
        "NSCameraUsageDescription": "Для съёмки фото и отправки в чат"
      }
    },
    "android": {
      "package": "com.anonymous.autoservice"
    }
  }
}
